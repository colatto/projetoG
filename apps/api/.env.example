# URL e Chaves do projeto Supabase local/deploy
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Credenciais e Endpoints Sienge (obrigatório para integração)
SIENGE_BASE_URL=https://api.sienge.com.br
SIENGE_API_KEY=your-sienge-api-key-here
SIENGE_API_SECRET=your-sienge-api-secret-here
SIENGE_WEBHOOK_SECRET=optional-inbound-webhook-secret
SIENGE_ENCRYPTION_KEY=32-byte-hex-key-for-credential-encryption

# Configurações do Backend / JWT
JWT_SECRET=super-secret-jwt-key
PORT=3000
NODE_ENV=development

# Notificações por e-mail (PRD-03) — Provedor Resend
EMAIL_PROVIDER_API_KEY=your-resend-api-key-here
EMAIL_FROM_ADDRESS=GRF Cotações <cotacoes@grfincorporadora.com>
FRONTEND_URL=http://localhost:5173
COMPRAS_EMAIL=compras@grfincorporadora.com
