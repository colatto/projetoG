# Copiar para api.env no servidor. Valores de exemplo — substituir tudo.

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Direct ou Session pooler — evitar Transaction pooler (6543) para pg-boss
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres?sslmode=require

JWT_SECRET=

SIENGE_BASE_URL=https://api.sienge.com.br
SIENGE_API_KEY=
SIENGE_API_SECRET=
SIENGE_WEBHOOK_SECRET=
SIENGE_ENCRYPTION_KEY=

EMAIL_PROVIDER_API_KEY=
EMAIL_FROM_ADDRESS=GRF Cotações <cotacoes@example.com>
FRONTEND_URL=https://grf.ruatrez.com
COMPRAS_EMAIL=compras@example.com

# CORS — lista separada por vírgula; sem definir, aceita qualquer origem
CORS_ALLOWED_ORIGINS=https://grf.ruatrez.com
