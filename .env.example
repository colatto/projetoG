# =============================================================================
# .env.example — projetoG / GRF Incorporadora
# =============================================================================
# Este arquivo documenta TODAS as variaveis de ambiente esperadas pelo projeto.
# Copie para .env (raiz) ou para o .env do modulo correspondente e preencha
# os valores reais antes de inicializar o workspace.
#
# ATENCAO: .env nunca deve ser commitado. Este arquivo (.env.example) e seguro
# para versionamento porque nao contem valores reais.
#
# Referencia: CLAUDE.md ## Variaveis de ambiente esperadas
# =============================================================================


# -----------------------------------------------------------------------------
# apps/web — Frontend SPA (React + TypeScript + Vite)
# Variaveis com prefixo VITE_ sao expostas ao bundle do cliente pela Vite.
# NAO coloque segredos com prefixo VITE_.
# -----------------------------------------------------------------------------

# URL publica do projeto Supabase (projeto dbGRF)
# Exemplo: https://lkfevrdhofxlmwjfhnru.supabase.co
VITE_SUPABASE_URL=

# Chave publica (anon key) do Supabase — segura para expor no cliente
VITE_SUPABASE_ANON_KEY=

# Endereco base da API dedicada (apps/api)
# Exemplo em dev local: http://localhost:3000
# Exemplo em producao: https://api.seudominio.com
VITE_API_BASE_URL=


# -----------------------------------------------------------------------------
# apps/api — Backend dedicado (TypeScript)
# Estas variaveis NAO devem ser expostas ao frontend.
# -----------------------------------------------------------------------------

# URL do projeto Supabase (projeto dbGRF)
# Exemplo: https://lkfevrdhofxlmwjfhnru.supabase.co
SUPABASE_URL=

# Chave de servico do Supabase (service_role) — SEGREDO, nunca expor ao cliente
SUPABASE_SERVICE_ROLE_KEY=

# URL base da API REST do Sienge
# Exemplo: https://api.sienge.com.br/nome-da-empresa/public/api/v1
SIENGE_BASE_URL=

# Credencial de acesso ao Sienge (API Key ou token Bearer)
# Confirmar o mecanismo de autenticacao exato com a equipe Sienge antes de preencher
SIENGE_API_KEY=

# Segredo para assinatura e verificacao de tokens JWT internos
# Gerar com: openssl rand -hex 64
JWT_SECRET=

# Porta de execucao do servidor da API em ambiente local
PORT=3000

# Ambiente de execucao (development | staging | production)
NODE_ENV=development


# -----------------------------------------------------------------------------
# workers/ — Processamento assincrono (polling, retry, follow-up)
# Workers compartilham as mesmas credenciais de infraestrutura da API.
# Duplicar aqui para permitir .env independente por modulo quando necessario.
# -----------------------------------------------------------------------------

# URL do projeto Supabase (mesma instancia da API)
SUPABASE_URL=

# Chave de servico do Supabase — SEGREDO
SUPABASE_SERVICE_ROLE_KEY=

# URL base da API REST do Sienge (mesma instancia da API)
SIENGE_BASE_URL=

# Credencial de acesso ao Sienge (mesma instancia da API)
SIENGE_API_KEY=


# -----------------------------------------------------------------------------
# Notas de implementacao
# -----------------------------------------------------------------------------
# 1. Ao inicializar o monorepo, avaliar se .env deve ser centralizado na raiz
#    ou fragmentado por modulo (apps/web/.env, apps/api/.env, workers/.env).
#    Recomendacao: fragmentado por modulo para evitar vazamento de variaveis
#    de servidor (SUPABASE_SERVICE_ROLE_KEY, JWT_SECRET) ao processo da Vite.
#
# 2. O projeto Supabase provisionado e o dbGRF:
#    - Project ID: lkfevrdhofxlmwjfhnru
#    - Regiao: sa-east-1 (Sao Paulo)
#    - A URL e as chaves estao disponiveis no painel do Supabase.
#
# 3. Para obter as chaves do Supabase:
#    Painel > Settings > API > Project URL e Project API Keys
#
# 4. Para a credencial do Sienge, confirmar com a equipe antes de preencher:
#    - Mecanismo: API Key no header ou OAuth Bearer Token?
#    - URL base real do ambiente de homologacao e de producao do cliente GRF.
# =============================================================================
