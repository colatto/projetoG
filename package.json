{
  "name": "projetog-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "build": "node scripts/build-hostinger-api.mjs",
    "start:api": "node apps/api/dist/hostinger-entry.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "security:secrets": "node scripts/check-no-secrets.mjs",
    "security:audit": "pnpm audit",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "db:login": "pnpm dlx supabase login",
    "db:link": "pnpm dlx supabase link --project-ref lkfevrdhofxlmwjfhnru",
    "db:push": "pnpm dlx supabase db push",
    "db:pull": "pnpm dlx supabase db pull",
    "db:types": "pnpm dlx supabase gen types typescript --project-id lkfevrdhofxlmwjfhnru > packages/shared/src/database.types.ts"
  },
  "devDependencies": {
    "esbuild": "0.27.7",
    "esbuild-wasm": "0.27.7",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "@supabase/supabase-js": "^2.105.1"
  },
  "pnpm": {
    "overrides": {
      "@fastify/static": "9.1.1",
      "fast-jwt": "6.2.1",
      "follow-redirects": "1.16.0"
    },
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  }
}
